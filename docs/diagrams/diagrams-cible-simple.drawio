<mxfile host="app.diagrams.net" modified="2026-03-08T11:20:00.000Z" agent="Codex" version="24.7.17" editor="www.draw.io">
  <diagram id="to-be-functional-clean" name="TO-BE Functional Clean">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Schéma fonctionnel cible - GlycoPilot (version lisible)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=26;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="1100" height="40" as="geometry" />
        </mxCell>

        <mxCell id="patient" value="Réseau local patient&#xa;Front-end patient (mobile)&#xa;- Collecte capteur CGM (Bluetooth)&#xa;- Saisie manuelle glycémie&#xa;- Suivi médicaments / activité / nutrition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="220" width="420" height="210" as="geometry" />
        </mxCell>

        <mxCell id="proche" value="Réseau local proche&#xa;Front-end proche (mobile)&#xa;- Reçoit alertes et prédictions critiques&#xa;- Consulte historiques et tendances du patient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="500" width="420" height="170" as="geometry" />
        </mxCell>

        <mxCell id="medecin" value="Réseau local médecin&#xa;Front-end médecin (web)&#xa;- Accès aux historiques d'alertes patients&#xa;- Suivi médical et préparation des RDV" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="720" width="420" height="170" as="geometry" />
        </mxCell>

        <mxCell id="metier" value="Cœur métier (fonctionnel)&#xa;- Ingestion données CGM en temps réel&#xa;- Gestion glycémie (manuel + auto)&#xa;- Moteur alertes hypo/hyper + prédictions IA&#xa;- Historisation (mesures, alertes, actions)&#xa;- Rappels personnalisés (médicaments, activité, nutrition)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="560" y="300" width="540" height="260" as="geometry" />
        </mxCell>

        <mxCell id="backend" value="Réseau distant / Back-end&#xa;- API sécurisée + base de données&#xa;- IA et règles d'orchestration alertes&#xa;- Notifications multi-acteurs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1170" y="270" width="500" height="220" as="geometry" />
        </mxCell>

        <mxCell id="samu" value="SAMU / Urgences&#xa;Escalade automatique si&#xa;hypo/hyper grave non maîtrisée" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1170" y="90" width="500" height="120" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="Données patient (CGM + manuel + contexte)" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#7F6000;" edge="1" parent="1" source="patient" target="metier">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="Traitement / règles / prédictions" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#9673A6;" edge="1" parent="1" source="metier" target="backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="Alertes + rappels + historiques personnels" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#7F6000;" edge="1" parent="1" source="backend" target="patient">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="Alertes critiques + tendances patient" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#38761D;" edge="1" parent="1" source="backend" target="proche">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="Historiques alertes patients + suivi" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#A61C00;" edge="1" parent="1" source="backend" target="medecin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="Escalade urgence (si seuil critique persistant)" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#B85450;dashed=1;" edge="1" parent="1" source="backend" target="samu">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e7" value="Suivi aidant" style="endArrow=none;html=1;dashed=1;strokeWidth=2;strokeColor=#6AA84F;" edge="1" parent="1" source="patient" target="proche">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="Suivi médical" style="endArrow=none;html=1;dashed=1;strokeWidth=2;strokeColor=#E06666;" edge="1" parent="1" source="patient" target="medecin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="Légende&#xa;Flèches pleines: flux applicatifs principaux&#xa;Flèches pointillées: relations de coordination&#xa;Rouge pointillé: escalade d'urgence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F3F3;strokeColor=#B7B7B7;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1170" y="540" width="500" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
