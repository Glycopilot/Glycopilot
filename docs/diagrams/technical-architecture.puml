@startuml
title Glycopilot - Architecture Technique Globale

skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName Arial

actor "Utilisateur" as User

package "Clients" {
  component "App Mobile\nReact Native + Expo" as Mobile
  component "App Web\nReact" as Web
}

node "Docker Compose" {
  package "Backend Django" {
    component "REST API" as API
    component "Channels (WebSocket)" as WS

    package "Domaines API" {
      component "Auth\n/api/auth" as Auth
      component "Users/Profiles\n/api/users" as Users
      component "Glycemia\n/api/glycemia" as Gly
      component "Dashboard\n/api/v1/dashboard" as Dash
      component "Autres modules\nalerts/devices/doctors/..." as Other
    }
  }

  database "MySQL" as DB
  queue "Redis\n(channel layer + cache)" as Redis
}

User --> Mobile : Utilisation
User --> Web : Utilisation

Mobile --> API : HTTP REST + JWT
Web --> API : HTTP REST + JWT
Mobile --> WS : WebSocket + JWT\n/ws/glycemia

API --> Auth
API --> Users
API --> Gly
API --> Dash
API --> Other

WS --> Redis
Gly --> Redis
Dash --> Redis

Auth --> DB
Users --> DB
Gly --> DB
Dash --> DB
Other --> DB
@enduml
