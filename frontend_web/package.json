{
  "name": "frontend_web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "axios": "^1.7.7",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-scripts": "5.0.1",
    "react-toastify": "^10.0.6",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "http-proxy-middleware": "^3.0.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:unit": "react-scripts test --testPathPattern=__tests__/unit",
    "test:integration": "react-scripts test --testPathPattern=__tests__/integration",
    "test:ci": "react-scripts test --watchAll=false",
    "test:coverage": "react-scripts test --watchAll=false --coverage --runInBand",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/hooks/**/*.{js,jsx}",
      "src/lib/utils.js",
      "src/components/InputField.jsx",
      "src/components/Sidebar.jsx",
      "src/screens/HomeScreen.jsx",
      "src/screens/LoginScreen.jsx",
      "src/screens/SignInScreen.jsx",
      "src/screens/ProfileScreen.jsx",
      "src/services/passwordService.js",
      "src/services/toastService.js",
      "src/services/userService.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "src/index.js",
      "src/reportWebVitals.js",
      "src/setupProxy.js",
      "src/services/authService.js",
      "src/components/tour/",
      "src/screens/PatientsScreen.jsx"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
