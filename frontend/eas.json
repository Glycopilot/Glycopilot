{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8006/api",
        "EXPO_PUBLIC_WS_URL": "ws://localhost:8006"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://15.188.114.169/register/api",
        "EXPO_PUBLIC_WS_URL": "ws://15.188.114.169"
      }
    },
    "apk": {
      "environment": "production",
      "developmentClient": false,
      "distribution": "internal",
      "channel": "apk",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://15.188.114.169/register/api",
        "EXPO_PUBLIC_WS_URL": "ws://15.188.114.169",
        "EXPO_PUBLIC_S3_BUCKET": "glycopilot-aws-s3-bucket-img-artifacts"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://15.188.114.169/register/api",
        "EXPO_PUBLIC_WS_URL": "ws://15.188.114.169"
      }
    }
  }
}
