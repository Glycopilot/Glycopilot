<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <queries>
    <package android:name="tk.glucodata" />
  </queries>

  <application>
    <!-- Statically declared so Juggluco lists Glycopilot in its
         "Glucodata broadcast" recipient picker (which uses
         PackageManager.queryBroadcastReceivers). -->
    <receiver
      android:name=".juggluco.JugglucoReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="glucodata.Minute" />
      </intent-filter>
    </receiver>

    <service
      android:name=".ble.Libre2ForegroundService"
      android:exported="false"
      android:foregroundServiceType="connectedDevice" />
  </application>
</manifest>
